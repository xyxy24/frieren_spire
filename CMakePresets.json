{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2026",
      "displayName": "Windows x64 - Visual Studio 2026",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2026",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "windows-vs2022",
      "displayName": "Windows x64 - Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2022",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "20",
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-vs2026",
      "configurePreset": "windows-vs2026",
      "configuration": "Debug"
    },
    {
      "name": "release-vs2026",
      "configurePreset": "windows-vs2026",
      "configuration": "Release"
    },
    {
      "name": "debug-vs2022",
      "configurePreset": "windows-vs2022",
      "configuration": "Debug"
    },
    {
      "name": "release-vs2022",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "debug-vs2026",
      "configurePreset": "windows-vs2026",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-vs2026",
      "configurePreset": "windows-vs2026",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "debug-vs2022",
      "configurePreset": "windows-vs2022",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release-vs2022",
      "configurePreset": "windows-vs2022",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
